{
  "name": "mayday-ai-dialer",
  "version": "0.1.0",
  "private": true,
  "pnpm": {
    "overrides": {
      "kysely": "0.28.17"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "dotenv -e .env -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env -- drizzle-kit migrate",
    "db:push": "dotenv -e .env -- drizzle-kit push",
    "db:studio": "dotenv -e .env -- drizzle-kit studio",
    "auth:generate": "better-auth generate --config lib/auth.ts --output lib/db/auth-schema.ts --y",
    "seed:admin": "dotenv -e .env -- tsx scripts/create-admin.ts",
    "leads:harvest": "dotenv -e .env -- tsx scripts/harvest.ts",
    "leads:enrich": "dotenv -e .env -- tsx scripts/enrich-leads.ts",
    "briefs:backfill": "dotenv -e .env -- tsx scripts/backfill-briefs.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@neondatabase/serverless": "^1.1.0",
    "@twilio/voice-sdk": "^2.18.3",
    "better-auth": "^1.6.14",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "github-slugger": "^2.0.0",
    "googleapis": "^173.0.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "papaparse": "^5.5.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "twilio": "^6.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "xlsx": "^0.18.5"
  }
}
